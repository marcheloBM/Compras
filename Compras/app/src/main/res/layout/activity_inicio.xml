<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/holo_blue_bright"
    tools:context="com.example.march.compras.Inicio">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inicio"
        android:textColor="#080808"
        android:textSize="40dp"
        tools:layout_editor_absoluteX="111dp"
        tools:layout_editor_absoluteY="16dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true" />

    <Button
        android:id="@+id/btnComprar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:onClick="Comprar"
        android:text="Comprar"
        tools:layout_editor_absoluteX="147dp"
        tools:layout_editor_absoluteY="91dp"
        android:layout_marginTop="57dp"
        android:layout_below="@+id/textView"
        android:layout_centerHorizontal="true" />

    <Button
        android:id="@+id/btnLista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignStart="@+id/btnComprar"
        android:layout_below="@+id/btnComprar"
        android:layout_marginTop="34dp"
        android:onClick="Lista"
        android:text="Lista" />

    <Button
        android:id="@+id/btnCerrar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/btnLista"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="56dp"
        android:onClick="Cerrar"
        android:text="Cerrar Sesion" />

    <TextView
        android:id="@+id/lblUsuario3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/textView"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="13dp"
        android:text="TextView"
        android:textColor="@color/colorPrimary"
        android:textSize="20dp"/>

</RelativeLayout>
